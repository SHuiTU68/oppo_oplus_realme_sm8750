+    transition: opacity 250ms, transform 250ms; z-index: 1000; overflow: hidden;
+}
+.custom-select-wrapper.open .custom-select-menu { opacity: 1; visibility: visible; transform: translate3d(0, 0, 0); }
+.custom-select-option { padding: 12px 16px; cursor: pointer; transition: background-color 100ms; }
+.custom-select-option:hover { background-color: var(--md-sys-color-surface-container-highest); }
+.custom-select-option.selected {
+    background-color: var(--md-sys-color-secondary-container);
+    color: var(--md-sys-color-on-secondary-container);
+}
+#lang-setting-card { position: relative; z-index: 1000; }
+
+.empty-state {
+    flex: 1 1 auto; width: 100%; min-height: 46vh; gap: 14px; text-align: center;
+}
+.empty-face { font-size: clamp(42px, 13vw, 56px); font-weight: 600; }
+.empty-text { font-size: 16px; font-weight: 600; }
+.empty-list-placeholder:not(.empty-state), .error-message, .loading-spinner {
+    padding: 20px; text-align: center; color: var(--md-sys-color-on-surface-variant);
+}
+
+.modal-overlay {
