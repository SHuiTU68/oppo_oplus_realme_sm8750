+    flex: 0 0 auto; color: currentColor;
+}
+md-icon svg { width: 1em; height: 1em; fill: currentColor; display: block; }
+
+.segment-icon, .status-icon, .app-icon-img, .exclusion-app img, .setting-item img {
+    width: 40px; height: 40px; border-radius: 12px; flex: 0 0 auto;
+}
+.app-icon-img, .exclusion-app img, .setting-item img { object-fit: cover; }
+.segment-icon { color: var(--md-sys-color-on-surface-variant); }
+.status-icon { font-size: 28px; }
+
+.custom-switch {
+    display: inline-flex; align-items: center; position: relative;
