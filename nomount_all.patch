diff --git a/nomount_patch/module/webroot/styles.css b/nomount_patch/module/webroot/styles.css
new file mode 100644
index 0000000..a243d9a
--- /dev/null
+++ b/nomount_patch/module/webroot/styles.css
@@ -0,0 +1,393 @@
+@import "/internal/insets.css";
+@import "/internal/colors.css";
+@import "./theme.css";
+
+:root {
+    --nav-height: 74px;
+    --insets-top: var(--window-inset-top, env(safe-area-inset-top, 0px));
+    --insets-bottom: var(--window-inset-bottom, env(safe-area-inset-bottom, 0px));
+}
+
+*, *::before, *::after { box-sizing: border-box; }
+
+html, body {
+    height: 100%; width: 100%; margin: 0; padding: 0;
+    overflow: hidden;
+    font-family: var(--nm-font-family);
+    background: var(--md-sys-color-background);
+    color: var(--md-sys-color-on-surface);
+    -webkit-font-smoothing: antialiased;
+    -moz-osx-font-smoothing: grayscale;
+    -webkit-tap-highlight-color: transparent;
+}
+
+body { transition: opacity 250ms ease; }
+body.loading { opacity: 0; visibility: hidden; }
+
+.flex-center, .nav-item, .segment-icon, .status-icon, .app-icon-img, .exclusion-app img,
+.setting-item img, md-icon, .pull-to-refresh-indicator, .btn-hot-action, .custom-tonal-btn,
+.custom-fab, .modal-header, md-icon-button, .nav-icon, .empty-state, .search-box md-icon-button,
+.filter-option, .bottom-nav, .custom-select-trigger, .root_layout {
+    display: flex; align-items: center; justify-content: center;
+}
+
+.root_layout, .flex-col, .view-content.active, .home-segment-group, .settings-segment-group, .app-list,
+.list, .app-list-wrapper, .status-text-col, .info-data, .module-info, .exclusion-app .setting-text,
+.app-details, .app-meta, .empty-state, .modal-content, .nav-item {
+    display: flex; flex-direction: column;
+}
+
+.grid-card, .home-segment-row, .segment-card, .setting-item, .app-item, .home-status-card {
+    display: grid; align-items: center; gap: 16px;
+}
+
+.card, .home-status-card, .home-segment-row, .segment-card, .app-item {
+    background-color: var(--md-sys-color-surface-container);
+    transition: background-color 0.2s, transform 0.2s;
+}
+
+.home-segment-row, .segment-card {
+    min-height: 72px; padding: 12px 16px;
+    border-radius: var(--nm-segment-inner-corner);
+}
+
+
+.card, .home-status-card { border-radius: 16px; padding: 16px; }
+
+.page-container::-webkit-scrollbar, .app-list::-webkit-scrollbar,
+.view-content, .modal-overlay, .filter-menu, md-icon:not([data-icon]),
+.custom-switch .switch-input { display: none; }
+
+.page-container {
+    flex: 1; overflow-y: auto; position: relative; width: 100%;
+    padding-bottom: calc(var(--nav-height) + var(--insets-bottom) + var(--nm-page-bottom-gap));
+    -webkit-overflow-scrolling: touch; scrollbar-width: none;
+}
+
+.status-text-col, .info-data, .module-info, .app-details, .modal-overlay,
+.exclusion-app .setting-text { justify-content: center; min-width: 0; }
+
+.modal-header, .module-header, .filter-option { justify-content: space-between; }
+.root_layout { height: 100%; width: 100%; }
+
+.home-segment-row, .home-status-card { grid-template-columns: 40px minmax(0, 1fr); }
+.segment-card { grid-template-columns: 48px minmax(0, 1fr); }
+.setting-item { grid-template-columns: minmax(0, 1fr) auto; }
+
+.app-item {
+    grid-template-columns: 40px minmax(0, 1fr) auto;
+    min-height: 72px; cursor: pointer;
+}
+
+.status-text-col h2, .module-info h3, .setting-text h3, .info-label, .search-box input {
+    color: var(--md-sys-color-on-surface); font-size: 16px; font-weight: 500;
+}
+
+.status-label, .info-value, .file-count, .module-info p,
+.setting-text p, .app-pkg, .filter-option {
+    color: var(--md-sys-color-on-surface-variant); font-size: 14px;
+}
+
+.header-title { font-size: 28px; margin: 0 0 4px; padding-left: 4px; font-weight: 500; }
+.status-text-col h2 { font-size: 19px; }
+.app-pkg { font-size: 12px; }
+.uid-label { color: var(--md-sys-color-primary); font-size: 12px; font-weight: 600; }
+
+.segment-section-label {
+    margin: 8px 0 -4px 16px; color: var(--md-sys-color-primary);
