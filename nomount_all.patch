+    padding: 0 16px; min-height: 56px; display: flex; align-items: center;
+    gap: 12px; margin-bottom: 12px; flex-shrink: 0;
+}
+.search-box input { background: transparent; border: none; width: 100%; outline: none; }
+.search-box input::placeholder { color: var(--md-sys-color-on-surface-variant); }
+.search-box md-icon-button { margin-right: -8px; }
+
+.filter-menu {
+    background-color: var(--md-sys-color-surface-container-highest);
+    border-radius: 16px; padding: 12px 16px; margin-bottom: 12px;
+}
+.filter-menu.active { display: block; animation: fadeIn 0.2s; }
+.filter-option { font-size: 14px; }
+
+.app-list {
+    flex: 1 1 0; min-height: 0; overflow-y: auto;
+    padding-bottom: calc(16px + var(--insets-bottom));
+    scroll-padding-bottom: calc(16px + var(--insets-bottom));
+}
+.app-list-wrapper {
+    position: relative; flex: 1 1 0; min-height: 0;
+    overflow: hidden; border-radius: 8px 8px 0 0;
+}
+
+.pull-to-refresh-indicator {
+    position: absolute; top: -60px; left: 0; right: 0; height: 50px; z-index: 10; pointer-events: none;
+}
+.pull-to-refresh-indicator md-icon {
+    background-color: var(--md-sys-color-surface-container-high);
+    color: var(--md-sys-color-primary); width: 35px; height: 35px;
+    border-radius: 50%; box-shadow: 0 4px 8px rgba(0, 0, 0, 0.25);
+    transition: transform 0.3s ease-out;
+}
+.pull-to-refresh-indicator.refreshing md-icon { animation: spin 1s linear infinite; }
+
+.bottom-nav {
+    position: fixed; bottom: 0; left: 0; width: 100%; justify-content: space-evenly;
+    height: calc(var(--nav-height) + var(--insets-bottom)); padding-bottom: var(--insets-bottom);
+    background-color: var(--nm-nav-background);
+    backdrop-filter: blur(18px); -webkit-backdrop-filter: blur(18px); z-index: 100;
+}
+.nav-item {
+    color: var(--md-sys-color-on-surface-variant); opacity: 0.78;
+    width: 64px; height: 64px; cursor: pointer; user-select: none;
+    transition: color 0.2s, opacity 0.2s, transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
+}
+.nav-item.active { opacity: 1; color: var(--md-sys-color-on-secondary-container); }
+.nav-item.active .nav-icon { border-radius: 999px; background-color: var(--md-sys-color-secondary-container); }
+.nav-icon { width: 64px; height: 34px; }
+.nav-item span {
+    font-size: 12px; font-weight: 650; height: 0; opacity: 0; overflow: hidden;
+    transform: translate3d(0, -4px, 0); transition: all 0.2s;
+}
+.nav-item.active span { height: 16px; margin-top: 5px; opacity: 1; transform: translate3d(0, 0, 0); }
+
+#fab-container {
+    position: fixed; bottom: calc(var(--nav-height) + var(--insets-bottom) + 16px);
+    right: 16px; z-index: 90; opacity: 0; transform: scale(0.8);
+    pointer-events: none; transition: transform 0.3s, opacity 0.2s;
+}
+#fab-container.visible { opacity: 1; transform: scale(1); pointer-events: auto; }
+
+.custom-switch .switch-thumb, .custom-fab, .custom-tonal-btn,
+.pull-to-refresh-indicator md-icon { will-change: transform; }
+
+@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
+@keyframes fadeIn { from { opacity: 0; transform: translate3d(0, 8px, 0) scale(0.98); } to { opacity: 1; transform: translate3d(0, 0, 0) scale(1); } }
+@keyframes slideUp { from { transform: translate3d(0, 100%, 0); } to { transform: translate3d(0, 0, 0); } }
+
+::selection { background: var(--md-sys-color-primary-container); color: var(--md-sys-color-on-primary-container); }
+
+@media (min-width: 640px) {
+    .view-content { max-width: 720px; margin: 0 auto; width: 100%; }
+}
+
+@media (prefers-reduced-motion: reduce) {
+    *, *::before, *::after {
+        animation-duration: 1ms !important; transition-duration: 1ms !important; scroll-behavior: auto !important;
+    }
+}
