+    viewLoadState['view-home'] = true;
+    loadHome();
+    document.body.classList.remove('loading');
+
+    try {
+        if (!viewLoadState['view-modules']) loadModules();
+        if (!viewLoadState['view-exclusions']) loadExclusions();
+        if (!viewLoadState['view-options']) loadOptions();
+    } catch {}
+});
