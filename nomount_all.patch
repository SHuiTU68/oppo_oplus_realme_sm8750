+
+.view-content {
+    padding: calc(var(--insets-top) + var(--nm-page-padding-top)) var(--nm-page-padding-inline) var(--nm-page-padding-inline);
+    animation: fadeIn 360ms cubic-bezier(0.7, 0, 0, 1.5);
+}
+.view-content.active { gap: var(--nm-gap-relaxed); }
+
+#view-modules, #view-exclusions, #view-options {
+    min-height: calc(100vh - var(--nav-height) - var(--insets-bottom) - var(--nm-page-bottom-gap));
+}
+
+.list, .module-header { gap: var(--nm-gap-relaxed); }
+.home-segment-group, .settings-segment-group, .app-list { gap: var(--nm-segment-gap); }
+.home-segment-group> :first-child, .settings-segment-group> :first-child, .app-list> :first-child {
+    border-start-start-radius: var(--nm-segment-outer-corner);
+    border-start-end-radius: var(--nm-segment-outer-corner);
+}
+.home-segment-group> :last-child, .settings-segment-group> :last-child, .app-list> :last-child {
+    border-end-start-radius: var(--nm-segment-outer-corner);
+    border-end-end-radius: var(--nm-segment-outer-corner);
+}
+.home-segment-group> :only-child, .settings-segment-group> :only-child, .app-list> :only-child {
+    border-radius: var(--nm-segment-outer-corner);
+}
+
+.system-chip {
+    background: var(--md-sys-color-secondary-container);
+    color: var(--md-sys-color-on-secondary-container);
+    border-radius: 4px; font-size: 10px; padding: 2px 6px; font-weight: bold;
+}
+
+.module-header { display: flex; align-items: flex-start; margin-bottom: 8px; }
+.module-divider { height: 1px; background-color: rgba(120, 120, 120, 0.2); width: 100%; }
+.module-extension { display: flex; justify-content: flex-end; margin-top: 12px; }
+
+.exclusion-app { display: flex; align-items: center; gap: var(--nm-gap-relaxed); min-width: 0; overflow: hidden; }
+.app-meta { align-items: flex-end; gap: 4px; flex: 0 0 auto; text-align: right; }
+
+.custom-select-wrapper { position: relative; width: min-content; word-break: keep-all; user-select: none; }
+.custom-select-trigger {
+    height: 52px; padding: 0 12px; gap: 4px; border: 1px solid currentColor;
+    border-radius: 12px; font-size: 16px; cursor: pointer; transition: all 150ms ease;
+}
+.dropdown-arrow { transition: transform 150ms ease; margin-right: -6px; }
+.custom-select-wrapper.open .custom-select-trigger {
+    border-color: var(--md-sys-color-primary);
+    box-shadow: inset 0 0 0 1px var(--md-sys-color-primary);
+}
+.custom-select-wrapper.open .dropdown-arrow { transform: rotate(180deg); color: var(--md-sys-color-primary); }
+.custom-select-menu {
+    position: absolute; top: calc(100% + 4px); right: 0;
