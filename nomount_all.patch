+}
+.custom-switch:active .switch-thumb { width: 28px; }
+
+.top-app-bar {
+    --top-app-bar-opacity: 0; --top-app-title-opacity: 0;
+    position: fixed; top: 0; left: 0; right: 0; z-index: 90;
