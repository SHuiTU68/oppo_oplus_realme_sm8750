+NOMOUNT_DATA="/data/adb/nomount"
+LOG_FILE="$NOMOUNT_DATA/nomount.log"
+BOOT_SEMAPHORE="$NOMOUNT_DATA/.booting"
+TARGET_PARTITIONS="system vendor product system_ext odm oem"
